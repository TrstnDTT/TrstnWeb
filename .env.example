# EmailJS (formulaire Cheveux & Co — réservation)
# Copier vers .env.local et renseigner les valeurs depuis https://dashboard.emailjs.com
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Template dédié — formulaire « commerce local / lead » (ContactLead)
# Sous Next.js ce serait NEXT_PUBLIC_EMAILJS_TEMPLATE_ID_LEAD ; ici Vite exige le préfixe VITE_
VITE_EMAILJS_TEMPLATE_ID_LEAD=

# Stripe (client + server)
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIAL_DEPOSIT=
STRIPE_PRICE_ESSENTIAL_SUB=
STRIPE_PRICE_BOOST_DEPOSIT=
# Abonnement mensuel Pack BOOST (tarif affiché : 60€/mois — créer le Price récurrent correspondant dans Stripe)
STRIPE_PRICE_BOOST_SUB=

# EmailJS serveur (webhook de bienvenue)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID_WELCOME=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Resend — email de bienvenue après paiement Stripe (webhook)
# Le paquet npm officiel est `resend` (il n’y a pas de @resend/node sur npm).
RESEND_API_KEY=
# Expéditeur vérifié dans Resend, ex. TrstnWeb <newsletter@tondomaine.com>
RESEND_FROM_EMAIL=